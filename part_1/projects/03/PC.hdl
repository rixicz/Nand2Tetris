CHIP PC {
    IN in[16], reset, load, inc;
    OUT out[16];
    
    PARTS:
    Mux16(a=again , b=incout , sel=inc , out=mux1 );
    Mux16(a=mux1 , b=in , sel=load , out=loaded );
    Mux16(a=loaded , b=false , sel=reset , out=mux3 );
    Register(in=mux3 , load=true , out=out, out=again );
    Inc16(in=again , out=incout ); 
}
